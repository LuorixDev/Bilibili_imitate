{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "noEmit": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "files": ["src/main/index.ts", "src/preload/index.ts"],
  "include": ["src/main/**/*.ts", "src/preload/**/*.ts", "electron/**/*.ts"]
}
