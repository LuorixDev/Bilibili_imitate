{
  "name": "bilibili-electron-client",
  "private": true,
  "version": "0.1.0",
  "description": "Electron + Vue3 desktop video platform client demo",
  "homepage": "https://example.com",
  "author": {
    "name": "shapaper",
    "email": "shapaper@example.com"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n renderer,main,preload,electron -c blue,green,magenta,cyan \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:preload\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "esbuild src/main/index.ts --bundle --platform=node --outfile=dist-electron/main.js --external:electron --sourcemap --watch",
    "dev:preload": "esbuild src/preload/index.ts --bundle --platform=node --outfile=dist-electron/preload.js --external:electron --sourcemap --watch",
    "dev:electron": "wait-on tcp:5173 dist-electron/main.js dist-electron/preload.js && VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "npm run build:renderer && npm run build:main && npm run build:preload",
    "build:renderer": "vite build",
    "build:main": "esbuild src/main/index.ts --bundle --platform=node --outfile=dist-electron/main.js --external:electron --minify --sourcemap",
    "build:preload": "esbuild src/preload/index.ts --bundle --platform=node --outfile=dist-electron/preload.js --external:electron --minify --sourcemap",
    "build:electron": "npm run build && electron-builder",
    "build:electron:all": "npm run build && electron-builder -mwl",
    "build:electron:win": "npm run build && electron-builder -w",
    "build:electron:mac": "npm run build && electron-builder -m",
    "build:electron:linux": "npm run build && electron-builder -l",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "lint": "eslint . --ext .ts,.vue",
    "format": "prettier . --write"
  },
  "build": {
    "appId": "com.bilibili.desktop.demo",
    "productName": "Bilibili Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "maintainer": "shapaper <shapaper@example.com>",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "dependencies": {
    "pinia": "^2.1.7",
    "vue": "^3.4.38",
    "vue-router": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "concurrently": "^8.2.2",
    "electron": "^30.0.6",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.23.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.27.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.3",
    "wait-on": "^7.2.0"
  }
}
